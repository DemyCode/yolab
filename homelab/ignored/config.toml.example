# YoLab Homelab Configuration
# Copy this file to config.toml and customize for your setup

[homelab]
hostname = "yolab-client"
timezone = "UTC"
locale = "en_US.UTF-8"
ssh_port = 22
# Root SSH public key (optional - for root access)
root_ssh_key = ""
# SSH public keys for homelab user (required)
allowed_ssh_keys = [
    "ssh-ed25519 AAAA... user@host"
]
# Hashed password for homelab user (optional - for sudo access)
# Generated by installer or use: mkpasswd -m sha-512
homelab_password_hash = ""
# Git remote URL for updates (required if using installer)
git_remote = "https://github.com/DemyCode/yolab.git"

[disk]
device = "/dev/sda"
esp_size = "500M"
swap_size = "8G"

[docker]
enabled = false
# Optional URL to download docker-compose.yml from
compose_url = ""

# YoLab tunnel — makes your homelab reachable via a public IPv6 address.
# Filled in automatically by the installer when you register a tunnel.
[tunnel]
enabled = false
platform_api_url = "https://api.yolab.dev"
account_token = "your-account-token-here"
service_name = "homelab"
service_id = 0
wg_private_key = ""
wg_public_key = ""
sub_ipv6 = ""
wg_server_endpoint = ""
wg_server_public_key = ""

# WiFi configuration (optional)
[wifi]
enabled = false
ssid = "YourWiFiSSID"
psk = "YourWiFiPassword"
