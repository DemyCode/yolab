[homelab]
hostname = "yolab-client"
timezone = "UTC"
locale = "en_US.UTF-8"
ssh_port = 22
root_ssh_key = ""
allowed_ssh_keys = [
    "ssh-ed25519 AAAA... user@host"
]
homelab_password_hash = ""
git_remote = "https://github.com/DemyCode/yolab.git"

[disk]
device = "/dev/sda"
esp_size = "500M"
swap_size = "8G"

[docker]
enabled = false
compose_url = ""

[tunnel]
enabled = false
platform_api_url = "https://api.yolab.dev"
account_token = "your-account-token-here"
service_name = "homelab"
service_id = 0
wg_private_key = ""
wg_public_key = ""
sub_ipv6 = ""
wg_server_endpoint = ""
wg_server_public_key = ""

[wifi]
enabled = false
ssid = "YourWiFiSSID"
psk = "YourWiFiPassword"

[swarm]
enabled = false
mode = "manager"

[node]
node_id = ""

[node.k3s]
role = "server"
token = ""
server_addr = ""
