apiVersion: v1
kind: Namespace
metadata:
  name: yolab-{{ instance_name }}
  labels:
    yolab.io/managed: "true"
  annotations:
    yolab.io/app-id: "{{ app_id }}"
    yolab.io/tunnel-url: "{{ subdomain_tunnel.url }}"
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: yolab-{{ instance_name }}-data
spec:
  capacity:
    storage: 50Gi
  accessModes:
    - ReadWriteMany
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  nfs:
    server: "{{ disk.host }}"
    path: "{{ disk.path }}"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ instance_name }}-data
  namespace: yolab-{{ instance_name }}
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: ""
  volumeName: yolab-{{ instance_name }}-data
  resources:
    requests:
      storage: 50Gi
---
apiVersion: v1
kind: Secret
metadata:
  name: gitea-secrets
  namespace: yolab-{{ instance_name }}
type: Opaque
stringData:
  wg_config: |
    [Interface]
    PrivateKey = {{ subdomain_tunnel.wg_private_key }}
    Table = off
    PostUp = ip -6 address add {{ subdomain_tunnel.sub_ipv6 }}/128 dev wg0 || true; ip -6 rule add from {{ subdomain_tunnel.sub_ipv6 }} lookup 51820 priority 100 || true; ip -6 route add ::/0 dev wg0 table 51820 || true
    PreDown = ip -6 rule del from {{ subdomain_tunnel.sub_ipv6 }} lookup 51820 priority 100 || true; ip -6 route del ::/0 dev wg0 table 51820 || true; ip -6 address del {{ subdomain_tunnel.sub_ipv6 }}/128 dev wg0 || true

    [Peer]
    PublicKey = {{ subdomain_tunnel.wg_server_public_key }}
    Endpoint = {{ subdomain_tunnel.wg_server_endpoint }}
    AllowedIPs = ::/0
    PersistentKeepalive = 25
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: gitea-caddy
  namespace: yolab-{{ instance_name }}
data:
  Caddyfile: |
    {{ subdomain_tunnel.domain }} {
      reverse_proxy localhost:3001
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gitea
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gitea
  template:
    metadata:
      labels:
        app: gitea
    spec:
      initContainers:
      - name: ssh-host-keys
        image: docker.gitea.com/gitea:1.25.4
        command:
        - sh
        - -c
        - |
          mkdir -p /ssh-store
          if [ ! -f /ssh-store/ssh_host_ed25519_key ]; then
            ssh-keygen -t ed25519 -f /ssh-store/ssh_host_ed25519_key -N ""
          fi
          cp /ssh-store/ssh_host_ed25519_key /ssh-live/ssh_host_ed25519_key
          chmod 600 /ssh-live/ssh_host_ed25519_key
        volumeMounts:
        - name: data
          mountPath: /ssh-store
          subPath: {{ instance_name }}/gitea-ssh
        - name: ssh-host-keys
          mountPath: /ssh-live

      containers:
      - name: wireguard
        image: wg-sidecar:latest
        imagePullPolicy: Never
        securityContext:
          privileged: true
        volumeMounts:
        - name: wg-secret
          mountPath: /etc/wireguard

      - name: gitea
        image: docker.gitea.com/gitea:1.25.4
        env:
        - name: USER_UID
          value: "1000"
        - name: USER_GID
          value: "1000"
        - name: GITEA__server__DOMAIN
          value: "{{ subdomain_tunnel.domain }}"
        - name: GITEA__server__ROOT_URL
          value: "https://{{ subdomain_tunnel.domain }}"
        - name: GITEA__server__HTTP_PORT
          value: "3000"
        - name: GITEA__server__SSH_DOMAIN
          value: "{{ subdomain_tunnel.domain }}"
        - name: GITEA__server__SSH_PORT
          value: "22"
        - name: GITEA__database__DB_TYPE
          value: "sqlite3"
        - name: GITEA__database__PATH
          value: "/data/gitea/gitea.db"
        - name: GITEA__log__MODE
          value: "console"
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/gitea
        - name: ssh-host-keys
          mountPath: /data/ssh

      - name: anubis
        image: ghcr.io/techarohq/anubis:latest
        env:
        - name: BIND
          value: ":3001"
        - name: TARGET
          value: "http://localhost:3000"
        - name: OG_PASSTHROUGH
          value: "true"

      - name: caddy
        image: caddy:2
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/caddy
        - name: caddy-config
          mountPath: /etc/caddy/Caddyfile
          subPath: Caddyfile

      volumes:
      - name: wg-secret
        secret:
          secretName: gitea-secrets
          items:
          - key: wg_config
            path: wg0.conf
      - name: caddy-config
        configMap:
          name: gitea-caddy
      - name: ssh-host-keys
        emptyDir: {}
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
