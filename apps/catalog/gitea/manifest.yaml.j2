apiVersion: v1
kind: Namespace
metadata:
  name: yolab-{{ instance_name }}
  labels:
    yolab.io/managed: "true"
  annotations:
    yolab.io/app-id: "{{ app_id }}"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ instance_name }}-data
  namespace: yolab-{{ instance_name }}
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: yolab-cephfs
  resources:
    requests:
      storage: 50Gi
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: gitea-caddy
  namespace: yolab-{{ instance_name }}
data:
  Caddyfile: |
    {$YOLAB_FQDN} {
      reverse_proxy localhost:3001
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gitea
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gitea
  template:
    metadata:
      labels:
        app: gitea
    spec:
      initContainers:
      - name: wg-register
        image: ghcr.io/demycode/wg-register:main-latest@sha256:7c914fd218a480edc831867346a02eb5f9806c8cf7a76e6c0af8ae8de8bf9da7
        env:
        - name: PLATFORM_API_URL
          value: "{{ platform_api_url }}"
        - name: ACCOUNT_TOKEN
          value: "{{ account_token }}"
        - name: SERVICE_NAME
          value: "{{ service_name }}"
        volumeMounts:
        - name: wireguard
          mountPath: /wireguard
        - name: yolab
          mountPath: /yolab
        - name: data
          mountPath: /state
          subPath: "{{ instance_name }}/yolab-state"

      - name: ssh-host-keys
        image: docker.gitea.com/gitea:1.25.4@sha256:17d18218be2dad1f8ed402a4f906989505c90ab8b66ee9befcecfb5d470133e7
        command:
        - sh
        - -c
        - |
          mkdir -p /ssh-store
          if [ ! -f /ssh-store/ssh_host_ed25519_key ]; then
            ssh-keygen -t ed25519 -f /ssh-store/ssh_host_ed25519_key -N ""
          fi
          cp /ssh-store/ssh_host_ed25519_key /ssh-live/ssh_host_ed25519_key
          chmod 600 /ssh-live/ssh_host_ed25519_key
        volumeMounts:
        - name: data
          mountPath: /ssh-store
          subPath: {{ instance_name }}/gitea-ssh
        - name: ssh-host-keys
          mountPath: /ssh-live

      - name: regenerate-auth-keys
        image: docker.gitea.com/gitea:1.25.4@sha256:17d18218be2dad1f8ed402a4f906989505c90ab8b66ee9befcecfb5d470133e7
        command:
        - sh
        - -c
        - |
          mkdir -p /data/git/.ssh
          gitea admin regenerate keys || true
        env:
        - name: GITEA__database__DB_TYPE
          value: "postgres"
        - name: GITEA__database__HOST
          value: "postgres.yolab-{{ instance_name }}.svc.cluster.local:5432"
        - name: GITEA__database__NAME
          value: gitea
        - name: GITEA__database__USER
          value: gitea
        - name: GITEA__database__PASSWD
          value: gitea
        - name: GITEA__server__SSH_KEY_PATH
          value: "/data/git/.ssh/authorized_keys"
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/gitea
        - name: git-home
          mountPath: /data/git

      containers:
      - name: wireguard
        image: ghcr.io/demycode/wg-sidecar:latest@sha256:d7706338f231b0e54a8ac6c4a2940f5d9d8c2ac017a69dd378250359ee3d98c1
        securityContext:
          privileged: true
        volumeMounts:
        - name: wireguard
          mountPath: /etc/wireguard

      - name: gitea
        image: docker.gitea.com/gitea:1.25.4@sha256:17d18218be2dad1f8ed402a4f906989505c90ab8b66ee9befcecfb5d470133e7
        readinessProbe:
          httpGet:
            path: /api/healthz
            port: 3000
          initialDelaySeconds: 15
          periodSeconds: 10
        livenessProbe:
          httpGet:
            path: /api/healthz
            port: 3000
          initialDelaySeconds: 60
          periodSeconds: 20
          failureThreshold: 3
        command:
        - /bin/sh
        - -c
        - |
          . /yolab/env
          export GITEA__server__DOMAIN=$YOLAB_FQDN
          export GITEA__server__ROOT_URL=https://$YOLAB_FQDN
          export GITEA__server__SSH_DOMAIN=$YOLAB_FQDN
          exec /usr/bin/entrypoint
        env:
        - name: USER_UID
          value: "1000"
        - name: USER_GID
          value: "1000"
        - name: GITEA__server__HTTP_PORT
          value: "3000"
        - name: GITEA__server__SSH_PORT
          value: "22"
        - name: GITEA__database__DB_TYPE
          value: "postgres"
        - name: GITEA__database__HOST
          value: "postgres.yolab-{{ instance_name }}.svc.cluster.local:5432"
        - name: GITEA__database__NAME
          value: gitea
        - name: GITEA__database__USER
          value: gitea
        - name: GITEA__database__PASSWD
          value: gitea
        - name: GITEA__log__MODE
          value: "console"
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/gitea
        - name: ssh-host-keys
          mountPath: /data/ssh
        - name: git-home
          mountPath: /data/git
        - name: yolab
          mountPath: /yolab

      - name: anubis
        image: ghcr.io/techarohq/anubis:latest@sha256:5cf4c0d6c7ea01a356c6685a779971bdd28d6a5a4a6719201f73a9c4ae108db0
        env:
        - name: BIND
          value: ":3001"
        - name: TARGET
          value: "http://localhost:3000"
        - name: OG_PASSTHROUGH
          value: "true"

      - name: caddy
        image: caddy:2@sha256:ec18ee54aab3315c22e25f3b2babda73ff8007d39b13b3bd1bfffa2f0444c7d9
        command:
        - /bin/sh
        - -c
        - |
          . /yolab/env && exec caddy run --config /etc/caddy/Caddyfile --adapter caddyfile
        readinessProbe:
          tcpSocket:
            port: 80
          initialDelaySeconds: 5
          periodSeconds: 10
        livenessProbe:
          tcpSocket:
            port: 80
          initialDelaySeconds: 15
          periodSeconds: 20
          failureThreshold: 3
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/caddy
        - name: caddy-config
          mountPath: /etc/caddy/Caddyfile
          subPath: Caddyfile
        - name: yolab
          mountPath: /yolab

      volumes:
      - name: wireguard
        emptyDir: {}
      - name: yolab
        emptyDir: {}
      - name: caddy-config
        configMap:
          name: gitea-caddy
      - name: ssh-host-keys
        emptyDir: {}
      - name: git-home
        emptyDir: {}
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
    spec:
      containers:
      - name: postgres
        image: postgres:17-alpine
        readinessProbe:
          exec:
            command: ["pg_isready", "-U", "gitea"]
          initialDelaySeconds: 10
          periodSeconds: 10
        livenessProbe:
          exec:
            command: ["pg_isready", "-U", "gitea"]
          initialDelaySeconds: 30
          periodSeconds: 20
          failureThreshold: 3
        env:
        - name: POSTGRES_USER
          value: gitea
        - name: POSTGRES_PASSWORD
          value: gitea
        - name: POSTGRES_DB
          value: gitea
        volumeMounts:
        - name: data
          mountPath: /var/lib/postgresql/data
          subPath: {{ instance_name }}/postgres
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: v1
kind: Service
metadata:
  name: postgres
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: postgres
  ports:
  - port: 5432
    targetPort: 5432
