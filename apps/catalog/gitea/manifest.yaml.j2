apiVersion: v1
kind: Namespace
metadata:
  name: yolab-{{ instance_name }}
  labels:
    yolab.io/managed: "true"
  annotations:
    yolab.io/app-id: "{{ app_id }}"
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: yolab-{{ instance_name }}-data
spec:
  capacity:
    storage: 50Gi
  accessModes:
    - ReadWriteMany
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  nfs:
    server: "{{ disk.host }}"
    path: "{{ disk.path }}"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ instance_name }}-data
  namespace: yolab-{{ instance_name }}
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: ""
  volumeName: yolab-{{ instance_name }}-data
  resources:
    requests:
      storage: 50Gi
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: gitea-caddy
  namespace: yolab-{{ instance_name }}
data:
  Caddyfile: |
    {env.YOLAB_FQDN} {
      reverse_proxy localhost:3001
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gitea
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gitea
  template:
    metadata:
      labels:
        app: gitea
    spec:
      initContainers:
      - name: wg-register
        image: ghcr.io/demycode/wg-register:latest
        env:
        - name: PLATFORM_API_URL
          value: "{{ platform_api_url }}"
        - name: ACCOUNT_TOKEN
          value: "{{ account_token }}"
        - name: SERVICE_NAME
          value: "{{ service_name }}"
        volumeMounts:
        - name: wireguard
          mountPath: /wireguard
        - name: yolab
          mountPath: /yolab
        - name: data
          mountPath: /state
          subPath: "{{ instance_name }}/yolab-state"

      - name: ssh-host-keys
        image: docker.gitea.com/gitea:1.25.4
        command:
        - sh
        - -c
        - |
          mkdir -p /ssh-store
          if [ ! -f /ssh-store/ssh_host_ed25519_key ]; then
            ssh-keygen -t ed25519 -f /ssh-store/ssh_host_ed25519_key -N ""
          fi
          cp /ssh-store/ssh_host_ed25519_key /ssh-live/ssh_host_ed25519_key
          chmod 600 /ssh-live/ssh_host_ed25519_key
        volumeMounts:
        - name: data
          mountPath: /ssh-store
          subPath: {{ instance_name }}/gitea-ssh
        - name: ssh-host-keys
          mountPath: /ssh-live

      - name: regenerate-auth-keys
        image: docker.gitea.com/gitea:1.25.4
        command:
        - sh
        - -c
        - |
          mkdir -p /data/git/.ssh
          gitea admin regenerate keys || true
        env:
        - name: GITEA__database__DB_TYPE
          value: "sqlite3"
        - name: GITEA__database__PATH
          value: "/data/gitea/gitea.db"
        - name: GITEA__server__SSH_KEY_PATH
          value: "/data/git/.ssh/authorized_keys"
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/gitea
        - name: git-home
          mountPath: /data/git

      containers:
      - name: wireguard
        image: ghcr.io/demycode/wg-sidecar:latest
        securityContext:
          privileged: true
        volumeMounts:
        - name: wireguard
          mountPath: /etc/wireguard

      - name: gitea
        image: docker.gitea.com/gitea:1.25.4
        command:
        - /bin/sh
        - -c
        - |
          . /yolab/env
          export GITEA__server__DOMAIN=$YOLAB_FQDN
          export GITEA__server__ROOT_URL=https://$YOLAB_FQDN
          export GITEA__server__SSH_DOMAIN=$YOLAB_FQDN
          exec /usr/bin/entrypoint
        env:
        - name: USER_UID
          value: "1000"
        - name: USER_GID
          value: "1000"
        - name: GITEA__server__HTTP_PORT
          value: "3000"
        - name: GITEA__server__SSH_PORT
          value: "22"
        - name: GITEA__database__DB_TYPE
          value: "sqlite3"
        - name: GITEA__database__PATH
          value: "/data/gitea/gitea.db"
        - name: GITEA__log__MODE
          value: "console"
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/gitea
        - name: ssh-host-keys
          mountPath: /data/ssh
        - name: git-home
          mountPath: /data/git
        - name: yolab
          mountPath: /yolab

      - name: anubis
        image: ghcr.io/techarohq/anubis:latest
        env:
        - name: BIND
          value: ":3001"
        - name: TARGET
          value: "http://localhost:3000"
        - name: OG_PASSTHROUGH
          value: "true"

      - name: caddy
        image: caddy:2
        command:
        - /bin/sh
        - -c
        - |
          . /yolab/env && exec caddy run --config /etc/caddy/Caddyfile --adapter caddyfile
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/caddy
        - name: caddy-config
          mountPath: /etc/caddy/Caddyfile
          subPath: Caddyfile
        - name: yolab
          mountPath: /yolab

      volumes:
      - name: wireguard
        emptyDir: {}
      - name: yolab
        emptyDir: {}
      - name: caddy-config
        configMap:
          name: gitea-caddy
      - name: ssh-host-keys
        emptyDir: {}
      - name: git-home
        emptyDir: {}
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
