apiVersion: v1
kind: Namespace
metadata:
  name: yolab-{{ instance_name }}
  labels:
    yolab.io/managed: "true"
  annotations:
    yolab.io/app-id: "{{ app_id }}"
    yolab.io/tunnel-url: "{{ subdomain_tunnel.url }}"
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: yolab-{{ instance_name }}-data
spec:
  capacity:
    storage: 100Gi
  accessModes:
    - ReadWriteMany
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  nfs:
    server: "{{ disk.host }}"
    path: "{{ disk.path }}"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ instance_name }}-data
  namespace: yolab-{{ instance_name }}
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: ""
  volumeName: yolab-{{ instance_name }}-data
  resources:
    requests:
      storage: 100Gi
---
apiVersion: v1
kind: Secret
metadata:
  name: immich-secrets
  namespace: yolab-{{ instance_name }}
type: Opaque
stringData:
  db_password: "{{ db_password }}"
  wg_config: |
    [Interface]
    PrivateKey = {{ subdomain_tunnel.wg_private_key }}
    Address = {{ subdomain_tunnel.sub_ipv6 }}/128
    Table = off
    PostUp = ip -6 rule add from {{ subdomain_tunnel.sub_ipv6 }} lookup 51820 priority 100 || true; ip -6 route add ::/0 dev wg0 table 51820 || true
    PreDown = ip -6 rule del from {{ subdomain_tunnel.sub_ipv6 }} lookup 51820 priority 100 || true; ip -6 route del ::/0 dev wg0 table 51820 || true

    [Peer]
    PublicKey = {{ subdomain_tunnel.wg_server_public_key }}
    Endpoint = {{ subdomain_tunnel.wg_server_endpoint }}
    AllowedIPs = ::/0
    PersistentKeepalive = 25
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: immich-caddy
  namespace: yolab-{{ instance_name }}
data:
  Caddyfile: |
    {{ subdomain_tunnel.domain }} {
      reverse_proxy immich-server:2283
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gateway
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gateway
  template:
    metadata:
      labels:
        app: gateway
    spec:
      containers:
      - name: wireguard
        image: lscr.io/linuxserver/wireguard:latest
        securityContext:
          privileged: true
        volumeMounts:
        - name: wg-secret
          mountPath: /config/wg_confs
      - name: caddy
        image: caddy:2
        ports:
        - containerPort: 80
        - containerPort: 443
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/caddy
        - name: caddy-config
          mountPath: /etc/caddy/Caddyfile
          subPath: Caddyfile
      volumes:
      - name: wg-secret
        secret:
          secretName: immich-secrets
          items:
          - key: wg_config
            path: wg0.conf
      - name: caddy-config
        configMap:
          name: immich-caddy
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: immich-server
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: immich-server
  template:
    metadata:
      labels:
        app: immich-server
    spec:
      containers:
      - name: immich-server
        image: ghcr.io/immich-app/immich-server:release
        env:
        - name: DB_HOSTNAME
          value: postgres.yolab-{{ instance_name }}.svc.cluster.local
        - name: DB_USERNAME
          value: postgres
        - name: DB_PASSWORD
          valueFrom:
            secretKeyRef:
              name: immich-secrets
              key: db_password
        - name: DB_DATABASE_NAME
          value: immich
        - name: REDIS_HOSTNAME
          value: redis.yolab-{{ instance_name }}.svc.cluster.local
        - name: REDIS_PORT
          value: "6379"
        - name: IMMICH_MACHINE_LEARNING_URL
          value: http://immich-ml:3003
        - name: VIPS_NOVECTOR
          value: "1"
        volumeMounts:
        - name: data
          mountPath: /usr/src/app/upload
          subPath: {{ instance_name }}/uploads
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: v1
kind: Service
metadata:
  name: immich-server
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: immich-server
  ports:
  - port: 2283
    targetPort: 2283
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: immich-ml
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: immich-ml
  template:
    metadata:
      labels:
        app: immich-ml
    spec:
      containers:
      - name: immich-ml
        image: ghcr.io/immich-app/immich-machine-learning:release
        volumeMounts:
        - name: data
          mountPath: /cache
          subPath: {{ instance_name }}/ml-cache
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: v1
kind: Service
metadata:
  name: immich-ml
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: immich-ml
  ports:
  - port: 3003
    targetPort: 3003
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: redis
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: redis
  template:
    metadata:
      labels:
        app: redis
    spec:
      containers:
      - name: redis
        image: docker.io/valkey/valkey:8-bookworm
        livenessProbe:
          exec:
            command: ["redis-cli", "ping"]
          initialDelaySeconds: 10
          periodSeconds: 10
---
apiVersion: v1
kind: Service
metadata:
  name: redis
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: redis
  ports:
  - port: 6379
    targetPort: 6379
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
    spec:
      containers:
      - name: postgres
        image: ghcr.io/immich-app/postgres:14-vectorchord0.4.3-pgvectors0.2.0
        env:
        - name: POSTGRES_USER
          value: postgres
        - name: POSTGRES_PASSWORD
          valueFrom:
            secretKeyRef:
              name: immich-secrets
              key: db_password
        - name: POSTGRES_DB
          value: immich
        - name: POSTGRES_INITDB_ARGS
          value: "--data-checksums"
        volumeMounts:
        - name: data
          mountPath: /var/lib/postgresql/data
          subPath: {{ instance_name }}/postgres
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: v1
kind: Service
metadata:
  name: postgres
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: postgres
  ports:
  - port: 5432
    targetPort: 5432
