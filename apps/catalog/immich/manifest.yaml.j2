apiVersion: v1
kind: Namespace
metadata:
  name: yolab-{{ app_id }}
  labels:
    yolab.dev/managed: "true"
    yolab.dev/app: "{{ app_id }}"
  annotations:
    yolab.dev/tunnel-url: "https://{{ subdomain }}.{{ domain }}"
    yolab.dev/service-id: "{{ tunnel_service_id }}"
---
apiVersion: v1
kind: Secret
metadata:
  name: immich-secrets
  namespace: yolab-{{ app_id }}
type: Opaque
stringData:
  db_password: "{{ db_password }}"
  wg_config: |
    [Interface]
    PrivateKey = {{ wg_private_key }}
    Address = {{ sub_ipv6 }}/128
    Table = off
    PostUp = ip -6 rule add from {{ sub_ipv6 }} lookup 51820 priority 100 || true; ip -6 route add ::/0 dev wg0 table 51820 || true
    PreDown = ip -6 rule del from {{ sub_ipv6 }} lookup 51820 priority 100 || true; ip -6 route del ::/0 dev wg0 table 51820 || true

    [Peer]
    PublicKey = {{ wg_server_public_key }}
    Endpoint = {{ wg_server_endpoint }}
    AllowedIPs = ::/0
    PersistentKeepalive = 25
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: immich-caddy
  namespace: yolab-{{ app_id }}
data:
  Caddyfile: |
    {{ subdomain }}.{{ domain }} {
      reverse_proxy immich-server:2283
    }
---
# ── Gateway (WireGuard + Caddy) ───────────────────────────────────────────────
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gateway
  namespace: yolab-{{ app_id }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gateway
  template:
    metadata:
      labels:
        app: gateway
    spec:
      initContainers:
      - name: wg-init
        image: alpine:3.21
        securityContext:
          privileged: true
        command:
        - sh
        - -c
        - |
          apk add --no-cache wireguard-tools iproute2 iptables ip6tables -q
          cp /etc/wireguard-secret/wg_config /tmp/wg0.conf
          wg-quick up /tmp/wg0.conf
        volumeMounts:
        - name: wg-secret
          mountPath: /etc/wireguard-secret
      containers:
      - name: caddy
        image: caddy:2
        ports:
        - containerPort: 80
        - containerPort: 443
        volumeMounts:
        - name: caddy-config
          mountPath: /etc/caddy
        - name: data
          mountPath: /data
          subPath: caddy
      volumes:
      - name: wg-secret
        secret:
          secretName: immich-secrets
      - name: caddy-config
        configMap:
          name: immich-caddy
      - name: data
        persistentVolumeClaim:
          claimName: immich-data
---
# ── Immich Server ─────────────────────────────────────────────────────────────
apiVersion: apps/v1
kind: Deployment
metadata:
  name: immich-server
  namespace: yolab-{{ app_id }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: immich-server
  template:
    metadata:
      labels:
        app: immich-server
    spec:
      containers:
      - name: immich-server
        image: ghcr.io/immich-app/immich-server:release
        env:
        - name: DB_HOSTNAME
          value: postgres
        - name: DB_PORT
          value: "5432"
        - name: DB_USERNAME
          value: immich
        - name: DB_PASSWORD
          valueFrom:
            secretKeyRef:
              name: immich-secrets
              key: db_password
        - name: DB_DATABASE_NAME
          value: immich
        - name: REDIS_HOSTNAME
          value: redis
        - name: IMMICH_MACHINE_LEARNING_URL
          value: http://immich-ml:3003
        - name: VIPS_NOVECTOR
          value: "1"
        volumeMounts:
        - name: data
          mountPath: /usr/src/app/upload
          subPath: uploads
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: immich-data
---
apiVersion: v1
kind: Service
metadata:
  name: immich-server
  namespace: yolab-{{ app_id }}
spec:
  selector:
    app: immich-server
  ports:
  - port: 2283
    targetPort: 2283
---
# ── Machine Learning ──────────────────────────────────────────────────────────
apiVersion: apps/v1
kind: Deployment
metadata:
  name: immich-ml
  namespace: yolab-{{ app_id }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: immich-ml
  template:
    metadata:
      labels:
        app: immich-ml
    spec:
      containers:
      - name: immich-ml
        image: ghcr.io/immich-app/immich-machine-learning:release
        resources:
          limits:
            memory: 4Gi
        volumeMounts:
        - name: data
          mountPath: /cache
          subPath: ml-cache
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: immich-data
---
apiVersion: v1
kind: Service
metadata:
  name: immich-ml
  namespace: yolab-{{ app_id }}
spec:
  selector:
    app: immich-ml
  ports:
  - port: 3003
    targetPort: 3003
---
# ── Redis ─────────────────────────────────────────────────────────────────────
apiVersion: apps/v1
kind: Deployment
metadata:
  name: redis
  namespace: yolab-{{ app_id }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: redis
  template:
    metadata:
      labels:
        app: redis
    spec:
      containers:
      - name: redis
        image: docker.io/valkey/valkey:8-bookworm
        livenessProbe:
          exec:
            command: ["redis-cli", "ping"]
          initialDelaySeconds: 10
          periodSeconds: 10
---
apiVersion: v1
kind: Service
metadata:
  name: redis
  namespace: yolab-{{ app_id }}
spec:
  selector:
    app: redis
  ports:
  - port: 6379
    targetPort: 6379
---
# ── PostgreSQL ────────────────────────────────────────────────────────────────
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
  namespace: yolab-{{ app_id }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
    spec:
      containers:
      - name: postgres
        image: ghcr.io/immich-app/postgres:14-vectorchord0.4.3-pgvectors0.2.0
        env:
        - name: POSTGRES_USER
          value: immich
        - name: POSTGRES_PASSWORD
          valueFrom:
            secretKeyRef:
              name: immich-secrets
              key: db_password
        - name: POSTGRES_DB
          value: immich
        - name: POSTGRES_INITDB_ARGS
          value: "--data-checksums"
        volumeMounts:
        - name: data
          mountPath: /var/lib/postgresql/data
          subPath: postgres
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: immich-data
---
apiVersion: v1
kind: Service
metadata:
  name: postgres
  namespace: yolab-{{ app_id }}
spec:
  selector:
    app: postgres
  ports:
  - port: 5432
    targetPort: 5432
