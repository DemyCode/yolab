{
  "title": "Reactive Resume",
  "type": "object",
  "required": ["subdomain", "disk", "auth_secret"],
  "properties": {
    "subdomain": {
      "type": "string",
      "title": "Subdomain",
      "format": "tunnel",
      "default": "resume"
    },
    "disk": {
      "type": "object",
      "title": "Storage disk",
      "format": "disk"
    },
    "auth_secret": {
      "type": "string",
      "title": "Auth secret",
      "description": "Random secret for signing tokens. Generate: openssl rand -hex 32"
    }
  }
}
