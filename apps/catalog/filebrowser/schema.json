{
  "title": "File Browser",
  "type": "object",
  "required": ["subdomain", "password"],
  "properties": {
    "subdomain": {
      "type": "string",
      "title": "Subdomain",
      "format": "tunnel",
      "default": "filebrowser"
    },
    "password": {
      "type": "string",
      "title": "Admin password"
    },
    "storage_size": {
      "type": "string",
      "title": "Storage size",
      "default": "50Gi",
      "description": "How much CephFS storage to allocate (e.g. 20Gi, 100Gi, 500Gi)"
    }
  }
}
