apiVersion: v1
kind: Namespace
metadata:
  name: yolab-{{ instance_name }}
  labels:
    yolab.io/managed: "true"
  annotations:
    yolab.io/app-id: "{{ app_id }}"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ instance_name }}-data
  namespace: yolab-{{ instance_name }}
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: "yolab-{{ instance_name }}"
  resources:
    requests:
      storage: 20Gi
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: synapse-caddy
  namespace: yolab-{{ instance_name }}
data:
  Caddyfile: |
    {$YOLAB_FQDN} {
      handle /_matrix/* {
        reverse_proxy localhost:8008
      }
      handle /_synapse/* {
        reverse_proxy localhost:8008
      }
      handle {
        reverse_proxy localhost:80
      }
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gateway
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gateway
  template:
    metadata:
      labels:
        app: gateway
    spec:
      initContainers:
      - name: wg-register
        image: ghcr.io/demycode/wg-register:main-latest@sha256:7c914fd218a480edc831867346a02eb5f9806c8cf7a76e6c0af8ae8de8bf9da7
        env:
        - name: PLATFORM_API_URL
          value: "{{ platform_api_url }}"
        - name: ACCOUNT_TOKEN
          value: "{{ account_token }}"
        - name: SERVICE_NAME
          value: "{{ service_name }}"
        volumeMounts:
        - name: wireguard
          mountPath: /wireguard
        - name: yolab
          mountPath: /yolab
        - name: data
          mountPath: /state
          subPath: "{{ instance_name }}/yolab-state"

      - name: gen-secrets
        image: busybox:1.37
        command:
        - /bin/sh
        - -c
        - |
          SECRETS=/state/secrets.env
          if [ ! -f "$SECRETS" ]; then
            TMP=$(mktemp "${SECRETS}.XXXXXX")
            printf 'REGISTRATION_SHARED_SECRET=%s\n' "$(tr -dc a-f0-9 </dev/urandom | head -c 64)" > "$TMP"
            mv "$TMP" "$SECRETS"
          fi
          cp "$SECRETS" /yolab/secrets.env
        volumeMounts:
        - name: data
          mountPath: /state
          subPath: "{{ instance_name }}/yolab-state"
        - name: yolab
          mountPath: /yolab

      containers:
      - name: wireguard
        image: ghcr.io/demycode/wg-sidecar:latest@sha256:d7706338f231b0e54a8ac6c4a2940f5d9d8c2ac017a69dd378250359ee3d98c1
        securityContext:
          privileged: true
        volumeMounts:
        - name: wireguard
          mountPath: /etc/wireguard

      - name: caddy
        image: caddy:2@sha256:ec18ee54aab3315c22e25f3b2babda73ff8007d39b13b3bd1bfffa2f0444c7d9
        command:
        - /bin/sh
        - -c
        - |
          . /yolab/env && exec caddy run --config /etc/caddy/Caddyfile --adapter caddyfile
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/caddy
        - name: caddy-config
          mountPath: /etc/caddy/Caddyfile
          subPath: Caddyfile
        - name: yolab
          mountPath: /yolab

      - name: synapse
        image: matrixdotorg/synapse:latest
        command: ["/bin/sh", "-c"]
        args:
        - |
          . /yolab/env
          . /yolab/secrets.env
          SYNAPSE_DATA=/data/synapse
          mkdir -p "$SYNAPSE_DATA"
          if [ ! -f "$SYNAPSE_DATA/homeserver.yaml" ]; then
            python -m synapse.app.homeserver \
              --server-name "$YOLAB_FQDN" \
              --config-path "$SYNAPSE_DATA/homeserver.yaml" \
              --generate-config \
              --report-stats=no
            sed -i "s|database:|database:\n  name: psycopg2\n  args:\n    user: synapse\n    password: synapse\n    database: synapse\n    host: postgres.yolab-{{ instance_name }}.svc.cluster.local\n    cp_min: 5\n    cp_max: 10\n#|" "$SYNAPSE_DATA/homeserver.yaml" || true
            echo "registration_shared_secret: $REGISTRATION_SHARED_SECRET" >> "$SYNAPSE_DATA/homeserver.yaml"
            echo "suppress_key_server_warning: true" >> "$SYNAPSE_DATA/homeserver.yaml"
          fi
          exec python -m synapse.app.homeserver \
            --config-path "$SYNAPSE_DATA/homeserver.yaml"
        env:
        - name: SYNAPSE_REPORT_STATS
          value: "no"
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}
        - name: yolab
          mountPath: /yolab

      - name: element
        image: vectorim/element-web:latest
        command: ["/bin/sh", "-c"]
        args:
        - |
          . /yolab/env
          cat > /app/config.json <<EOF
          {
            "default_server_config": {
              "m.homeserver": {
                "base_url": "https://$YOLAB_FQDN",
                "server_name": "$YOLAB_FQDN"
              }
            },
            "brand": "Element",
            "integrations_ui_url": "",
            "integrations_rest_url": "",
            "integrations_widgets_urls": [],
            "bug_report_endpoint_url": "",
            "showLabsSettings": false
          }
          EOF
          exec nginx -g 'daemon off;'
        volumeMounts:
        - name: yolab
          mountPath: /yolab

      volumes:
      - name: wireguard
        emptyDir: {}
      - name: yolab
        emptyDir: {}
      - name: caddy-config
        configMap:
          name: synapse-caddy
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
    spec:
      containers:
      - name: postgres
        image: postgres:16-alpine
        env:
        - name: POSTGRES_USER
          value: synapse
        - name: POSTGRES_PASSWORD
          value: synapse
        - name: POSTGRES_DB
          value: synapse
        - name: POSTGRES_INITDB_ARGS
          value: "--encoding=UTF-8 --lc-collate=C --lc-ctype=C"
        volumeMounts:
        - name: data
          mountPath: /var/lib/postgresql/data
          subPath: {{ instance_name }}/postgres
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: v1
kind: Service
metadata:
  name: postgres
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: postgres
  ports:
  - port: 5432
    targetPort: 5432
