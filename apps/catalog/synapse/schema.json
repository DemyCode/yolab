{
  "title": "Matrix Synapse",
  "type": "object",
  "required": ["subdomain", "disk", "registration_shared_secret"],
  "properties": {
    "subdomain": {
      "type": "string",
      "title": "Subdomain",
      "format": "tunnel",
      "default": "matrix"
    },
    "disk": {
      "type": "object",
      "title": "Storage disk",
      "format": "disk"
    },
    "registration_shared_secret": {
      "type": "string",
      "title": "Registration shared secret",
      "description": "Secret for admin user registration. Generate: openssl rand -hex 32"
    }
  }
}
