apiVersion: v1
kind: Namespace
metadata:
  name: yolab-{{ instance_name }}
  labels:
    yolab.io/managed: "true"
  annotations:
    yolab.io/app-id: "{{ app_id }}"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ instance_name }}-data
  namespace: yolab-{{ instance_name }}
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: yolab-cephfs
  resources:
    requests:
      storage: 1Gi
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: 2fauth-caddy
  namespace: yolab-{{ instance_name }}
data:
  Caddyfile: |
    {$YOLAB_FQDN} {
      reverse_proxy localhost:8000
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gateway
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gateway
  template:
    metadata:
      labels:
        app: gateway
    spec:
      initContainers:
      - name: wg-register
        image: ghcr.io/demycode/wg-register:main-latest@sha256:7c914fd218a480edc831867346a02eb5f9806c8cf7a76e6c0af8ae8de8bf9da7
        env:
        - name: PLATFORM_API_URL
          value: "{{ platform_api_url }}"
        - name: ACCOUNT_TOKEN
          value: "{{ account_token }}"
        - name: SERVICE_NAME
          value: "{{ service_name }}"
        volumeMounts:
        - name: wireguard
          mountPath: /wireguard
        - name: yolab
          mountPath: /yolab
        - name: data
          mountPath: /state
          subPath: "{{ instance_name }}/yolab-state"

      - name: gen-secrets
        image: busybox:1.37
        command:
        - /bin/sh
        - -c
        - |
          SECRETS=/state/secrets.env
          if [ ! -f "$SECRETS" ]; then
            TMP=$(mktemp "${SECRETS}.XXXXXX")
            printf 'APP_KEY=base64:%s\n' "$(dd if=/dev/urandom bs=24 count=1 2>/dev/null | base64 | tr -d '\n')" > "$TMP"
            mv "$TMP" "$SECRETS"
          fi
          cp "$SECRETS" /yolab/secrets.env
        volumeMounts:
        - name: data
          mountPath: /state
          subPath: "{{ instance_name }}/yolab-state"
        - name: yolab
          mountPath: /yolab

      containers:
      - name: wireguard
        image: ghcr.io/demycode/wg-sidecar:latest@sha256:d7706338f231b0e54a8ac6c4a2940f5d9d8c2ac017a69dd378250359ee3d98c1
        securityContext:
          privileged: true
        volumeMounts:
        - name: wireguard
          mountPath: /etc/wireguard

      - name: caddy
        image: caddy:2@sha256:ec18ee54aab3315c22e25f3b2babda73ff8007d39b13b3bd1bfffa2f0444c7d9
        readinessProbe:
          tcpSocket:
            port: 80
          initialDelaySeconds: 5
          periodSeconds: 10
        livenessProbe:
          tcpSocket:
            port: 80
          initialDelaySeconds: 15
          periodSeconds: 20
          failureThreshold: 3
        command:
        - /bin/sh
        - -c
        - |
          . /yolab/env && exec caddy run --config /etc/caddy/Caddyfile --adapter caddyfile
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/caddy
        - name: caddy-config
          mountPath: /etc/caddy/Caddyfile
          subPath: Caddyfile
        - name: yolab
          mountPath: /yolab

      - name: 2fauth
        image: 2fauth/2fauth:latest
        readinessProbe:
          httpGet:
            path: /
            port: 8000
          initialDelaySeconds: 10
          periodSeconds: 10
        livenessProbe:
          httpGet:
            path: /
            port: 8000
          initialDelaySeconds: 30
          periodSeconds: 20
          failureThreshold: 3
        env:
        - name: APP_ENV
          value: production
        - name: DB_CONNECTION
          value: pgsql
        - name: DB_HOST
          value: "postgres.yolab-{{ instance_name }}.svc.cluster.local"
        - name: DB_PORT
          value: "5432"
        - name: DB_DATABASE
          value: 2fauth
        - name: DB_USERNAME
          value: 2fauth
        - name: DB_PASSWORD
          value: 2fauth
        - name: CACHE_DRIVER
          value: file
        - name: SESSION_DRIVER
          value: file
        command:
        - /bin/sh
        - -c
        - |
          . /yolab/env
          . /yolab/secrets.env
          export APP_URL="https://$YOLAB_FQDN"
          exec /entrypoint.sh
        volumeMounts:
        - name: data
          mountPath: /2fauth
          subPath: {{ instance_name }}/2fauth
        - name: yolab
          mountPath: /yolab

      volumes:
      - name: wireguard
        emptyDir: {}
      - name: yolab
        emptyDir: {}
      - name: caddy-config
        configMap:
          name: 2fauth-caddy
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
    spec:
      containers:
      - name: postgres
        image: postgres:17-alpine
        readinessProbe:
          exec:
            command: ["pg_isready", "-U", "2fauth"]
          initialDelaySeconds: 10
          periodSeconds: 10
        livenessProbe:
          exec:
            command: ["pg_isready", "-U", "2fauth"]
          initialDelaySeconds: 30
          periodSeconds: 20
          failureThreshold: 3
        env:
        - name: POSTGRES_USER
          value: 2fauth
        - name: POSTGRES_PASSWORD
          value: 2fauth
        - name: POSTGRES_DB
          value: 2fauth
        volumeMounts:
        - name: data
          mountPath: /var/lib/postgresql/data
          subPath: {{ instance_name }}/postgres
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: v1
kind: Service
metadata:
  name: postgres
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: postgres
  ports:
  - port: 5432
    targetPort: 5432
