apiVersion: v1
kind: Namespace
metadata:
  name: yolab-{{ instance_name }}
  labels:
    yolab.io/managed: "true"
  annotations:
    yolab.io/app-id: "{{ app_id }}"
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: yolab-{{ instance_name }}-data
spec:
  capacity:
    storage: 20Gi
  accessModes:
    - ReadWriteMany
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  nfs:
    server: "{{ disk.host }}"
    path: "{{ disk.path }}"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ instance_name }}-data
  namespace: yolab-{{ instance_name }}
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: ""
  volumeName: yolab-{{ instance_name }}-data
  resources:
    requests:
      storage: 20Gi
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: appflowy-caddy
  namespace: yolab-{{ instance_name }}
data:
  Caddyfile: |
    {$YOLAB_FQDN} {
      handle /gotrue/* {
        reverse_proxy gotrue.yolab-{{ instance_name }}.svc.cluster.local:9999
      }
      handle /minio-api/* {
        uri strip_prefix /minio-api
        reverse_proxy minio.yolab-{{ instance_name }}.svc.cluster.local:9000
      }
      handle /ws/* {
        reverse_proxy cloud.yolab-{{ instance_name }}.svc.cluster.local:8000
      }
      handle /api/* {
        reverse_proxy cloud.yolab-{{ instance_name }}.svc.cluster.local:8000
      }
      handle {
        reverse_proxy localhost:3000
      }
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gateway
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gateway
  template:
    metadata:
      labels:
        app: gateway
    spec:
      initContainers:
      - name: wg-register
        image: ghcr.io/demycode/wg-register:latest@sha256:e44c383ee410952cb87beb3c35531f35fa2ca10a2ae2ad5818862cdd48640872
        env:
        - name: PLATFORM_API_URL
          value: "{{ platform_api_url }}"
        - name: ACCOUNT_TOKEN
          value: "{{ account_token }}"
        - name: SERVICE_NAME
          value: "{{ service_name }}"
        volumeMounts:
        - name: wireguard
          mountPath: /wireguard
        - name: yolab
          mountPath: /yolab
        - name: data
          mountPath: /state
          subPath: "{{ instance_name }}/yolab-state"

      containers:
      - name: wireguard
        image: ghcr.io/demycode/wg-sidecar:latest@sha256:d7706338f231b0e54a8ac6c4a2940f5d9d8c2ac017a69dd378250359ee3d98c1
        securityContext:
          privileged: true
        volumeMounts:
        - name: wireguard
          mountPath: /etc/wireguard

      - name: caddy
        image: caddy:2@sha256:ec18ee54aab3315c22e25f3b2babda73ff8007d39b13b3bd1bfffa2f0444c7d9
        command:
        - /bin/sh
        - -c
        - |
          . /yolab/env && exec caddy run --config /etc/caddy/Caddyfile --adapter caddyfile
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/caddy
        - name: caddy-config
          mountPath: /etc/caddy/Caddyfile
          subPath: Caddyfile
        - name: yolab
          mountPath: /yolab

      - name: app
        image: appflowyinc/appflowy_web:latest
        env:
        - name: AF_BASE_URL
          value: ""
        ports:
        - containerPort: 3000

      volumes:
      - name: wireguard
        emptyDir: {}
      - name: yolab
        emptyDir: {}
      - name: caddy-config
        configMap:
          name: appflowy-caddy
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: cloud
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: cloud
  template:
    metadata:
      labels:
        app: cloud
    spec:
      containers:
      - name: cloud
        image: appflowyinc/appflowy_cloud:latest
        env:
        - name: RUST_LOG
          value: info
        - name: APPFLOWY_DATABASE_URL
          value: "postgres://appflowy:appflowy@postgres.yolab-{{ instance_name }}.svc.cluster.local:5432/appflowy"
        - name: APPFLOWY_REDIS_URI
          value: "redis://redis.yolab-{{ instance_name }}.svc.cluster.local:6379"
        - name: APPFLOWY_GOTRUE_JWT_SECRET
          value: "{{ jwt_secret }}"
        - name: APPFLOWY_GOTRUE_JWT_EXP
          value: "7200"
        - name: APPFLOWY_GOTRUE_BASE_URL
          value: "http://gotrue.yolab-{{ instance_name }}.svc.cluster.local:9999"
        - name: APPFLOWY_S3_USE_MINIO
          value: "true"
        - name: APPFLOWY_S3_MINIO_URL
          value: "http://minio.yolab-{{ instance_name }}.svc.cluster.local:9000"
        - name: APPFLOWY_S3_ACCESS_KEY
          value: minioadmin
        - name: APPFLOWY_S3_SECRET_KEY
          value: minioadmin
        - name: APPFLOWY_S3_BUCKET
          value: appflowy
        - name: APPFLOWY_S3_REGION
          value: us-east-1
        - name: APPFLOWY_ACCESS_CONTROL
          value: "true"
        - name: APPFLOWY_WEBSOCKET_MAILBOX_SIZE
          value: "6000"
        volumeMounts:
        - name: data
          mountPath: /app/data
          subPath: {{ instance_name }}/cloud
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: v1
kind: Service
metadata:
  name: cloud
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: cloud
  ports:
  - port: 8000
    targetPort: 8000
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: worker
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: worker
  template:
    metadata:
      labels:
        app: worker
    spec:
      containers:
      - name: worker
        image: appflowyinc/appflowy_worker:latest
        env:
        - name: RUST_LOG
          value: info
        - name: APPFLOWY_DATABASE_URL
          value: "postgres://appflowy:appflowy@postgres.yolab-{{ instance_name }}.svc.cluster.local:5432/appflowy"
        - name: APPFLOWY_REDIS_URI
          value: "redis://redis.yolab-{{ instance_name }}.svc.cluster.local:6379"
        - name: APPFLOWY_S3_USE_MINIO
          value: "true"
        - name: APPFLOWY_S3_MINIO_URL
          value: "http://minio.yolab-{{ instance_name }}.svc.cluster.local:9000"
        - name: APPFLOWY_S3_ACCESS_KEY
          value: minioadmin
        - name: APPFLOWY_S3_SECRET_KEY
          value: minioadmin
        - name: APPFLOWY_S3_BUCKET
          value: appflowy
        - name: APPFLOWY_S3_REGION
          value: us-east-1
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gotrue
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gotrue
  template:
    metadata:
      labels:
        app: gotrue
    spec:
      containers:
      - name: gotrue
        image: appflowyinc/gotrue:latest
        env:
        - name: GOTRUE_SITE_URL
          value: "appflowy-flutter://"
        - name: URI_ALLOW_LIST
          value: "*"
        - name: GOTRUE_JWT_SECRET
          value: "{{ jwt_secret }}"
        - name: GOTRUE_JWT_EXP
          value: "7200"
        - name: GOTRUE_DB_DRIVER
          value: postgres
        - name: DATABASE_URL
          value: "postgres://appflowy:appflowy@postgres.yolab-{{ instance_name }}.svc.cluster.local:5432/appflowy"
        - name: GOTRUE_SMTP_ADMIN_EMAIL
          value: "{{ admin_email }}"
        - name: GOTRUE_MAILER_AUTOCONFIRM
          value: "true"
        - name: GOTRUE_ADMIN_EMAIL
          value: "{{ admin_email }}"
        - name: GOTRUE_ADMIN_PASSWORD
          value: "{{ admin_password }}"
        - name: GOTRUE_EXTERNAL_EMAIL_ENABLED
          value: "true"
        - name: GOTRUE_RATE_LIMIT_EMAIL_SENT
          value: "100"
        - name: GOTRUE_LOG_LEVEL
          value: info
---
apiVersion: v1
kind: Service
metadata:
  name: gotrue
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: gotrue
  ports:
  - port: 9999
    targetPort: 9999
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: minio
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: minio
  template:
    metadata:
      labels:
        app: minio
    spec:
      containers:
      - name: minio
        image: minio/minio:latest
        command: ["minio", "server", "/data", "--console-address", ":9001"]
        env:
        - name: MINIO_ROOT_USER
          value: minioadmin
        - name: MINIO_ROOT_PASSWORD
          value: minioadmin
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/minio
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: v1
kind: Service
metadata:
  name: minio
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: minio
  ports:
  - name: api
    port: 9000
    targetPort: 9000
  - name: console
    port: 9001
    targetPort: 9001
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
    spec:
      containers:
      - name: postgres
        image: postgres:16-alpine
        env:
        - name: POSTGRES_USER
          value: appflowy
        - name: POSTGRES_PASSWORD
          value: appflowy
        - name: POSTGRES_DB
          value: appflowy
        - name: POSTGRES_INITDB_ARGS
          value: "--data-checksums"
        volumeMounts:
        - name: data
          mountPath: /var/lib/postgresql/data
          subPath: {{ instance_name }}/postgres
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: v1
kind: Service
metadata:
  name: postgres
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: postgres
  ports:
  - port: 5432
    targetPort: 5432
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: redis
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: redis
  template:
    metadata:
      labels:
        app: redis
    spec:
      containers:
      - name: redis
        image: redis:7.4-alpine
        command: ["redis-server"]
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/redis
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: v1
kind: Service
metadata:
  name: redis
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: redis
  ports:
  - port: 6379
    targetPort: 6379
