{
  "title": "AppFlowy",
  "type": "object",
  "required": ["subdomain", "storage", "admin_email", "admin_password"],
  "properties": {
    "subdomain": {
      "type": "string",
      "title": "Subdomain",
      "format": "tunnel",
      "default": "appflowy"
    },
    "storage": {
      "type": "object",
      "title": "Storage",
      "format": "storage"
    },
    "admin_email": {
      "type": "string",
      "title": "Admin email",
      "default": "admin@example.com"
    },
    "admin_password": {
      "type": "string",
      "title": "Admin password",
      "description": "Initial admin account password"
    }
  }
}
