apiVersion: v1
kind: Namespace
metadata:
  name: yolab-{{ instance_name }}
  labels:
    yolab.io/managed: "true"
  annotations:
    yolab.io/app-id: "{{ app_id }}"
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: yolab-{{ instance_name }}-data
spec:
  capacity:
    storage: 10Gi
  accessModes:
    - ReadWriteMany
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  nfs:
    server: "{{ disk.host }}"
    path: "{{ disk.path }}"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ instance_name }}-data
  namespace: yolab-{{ instance_name }}
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: ""
  volumeName: yolab-{{ instance_name }}-data
  resources:
    requests:
      storage: 10Gi
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: vaultwarden-caddy
  namespace: yolab-{{ instance_name }}
data:
  Caddyfile: |
    {$YOLAB_FQDN} {
      reverse_proxy vaultwarden:80
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gateway
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gateway
  template:
    metadata:
      labels:
        app: gateway
    spec:
      initContainers:
      - name: wg-register
        image: ghcr.io/demycode/wg-register:main-latest@sha256:7c914fd218a480edc831867346a02eb5f9806c8cf7a76e6c0af8ae8de8bf9da7
        env:
        - name: PLATFORM_API_URL
          value: "{{ platform_api_url }}"
        - name: ACCOUNT_TOKEN
          value: "{{ account_token }}"
        - name: SERVICE_NAME
          value: "{{ service_name }}"
        volumeMounts:
        - name: wireguard
          mountPath: /wireguard
        - name: yolab
          mountPath: /yolab
        - name: data
          mountPath: /state
          subPath: "{{ instance_name }}/yolab-state"

      containers:
      - name: wireguard
        image: ghcr.io/demycode/wg-sidecar:latest@sha256:d7706338f231b0e54a8ac6c4a2940f5d9d8c2ac017a69dd378250359ee3d98c1
        securityContext:
          privileged: true
        volumeMounts:
        - name: wireguard
          mountPath: /etc/wireguard

      - name: caddy
        image: caddy:2@sha256:ec18ee54aab3315c22e25f3b2babda73ff8007d39b13b3bd1bfffa2f0444c7d9
        command:
        - /bin/sh
        - -c
        - |
          . /yolab/env && exec caddy run --config /etc/caddy/Caddyfile --adapter caddyfile
        ports:
        - containerPort: 80
        - containerPort: 443
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/caddy
        - name: caddy-config
          mountPath: /etc/caddy/Caddyfile
          subPath: Caddyfile
        - name: yolab
          mountPath: /yolab

      volumes:
      - name: wireguard
        emptyDir: {}
      - name: yolab
        emptyDir: {}
      - name: caddy-config
        configMap:
          name: vaultwarden-caddy
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: vaultwarden
  namespace: yolab-{{ instance_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: vaultwarden
  template:
    metadata:
      labels:
        app: vaultwarden
    spec:
      containers:
      - name: vaultwarden
        image: vaultwarden/server:latest@sha256:d626d04934cd1192ad8ced1adb975099fca78cec33ab467d2d3c923cde7f3b0c
        env:
        - name: ROCKET_ADDRESS
          value: "::"
        volumeMounts:
        - name: data
          mountPath: /data
          subPath: {{ instance_name }}/vaultwarden
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: {{ instance_name }}-data
---
apiVersion: v1
kind: Service
metadata:
  name: vaultwarden
  namespace: yolab-{{ instance_name }}
spec:
  selector:
    app: vaultwarden
  ports:
  - port: 80
    targetPort: 80
